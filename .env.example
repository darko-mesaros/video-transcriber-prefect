NEBIUS_IAM_TOKEN="replace-with-nebius-iam-token"

NEBIUS_PIPELINE_AWS_ACCESS_KEY_ID="replace-with-s3-access-key"
NEBIUS_PIPELINE_AWS_SECRET_ACCESS_KEY="replace-with-s3-secret-key"

NEBIUS_PIPELINE_NEBIUS_PROJECT_ID="replace-with-project-id"
NEBIUS_PIPELINE_NEBIUS_SUBNET_ID="replace-with-subnet-id"
NEBIUS_PIPELINE_NEBIUS_BUCKET_ID="replace-with-bucket-id"

# Optional overrides. The defaults in config.py are usually fine, but CPU
# platform/preset may need to match your region.
NEBIUS_PIPELINE_NEBIUS_BUCKET="darko-mesaros-videos"
NEBIUS_PIPELINE_VIDEO_PREFIX="video/"
NEBIUS_PIPELINE_AUDIO_PREFIX="audio/"
NEBIUS_PIPELINE_DONE_VIDEO_PREFIX="DONE_video/"
NEBIUS_PIPELINE_DONE_AUDIO_PREFIX="DONE_audio/"
NEBIUS_PIPELINE_NEBIUS_ENDPOINT="https://storage.us-central1.nebius.cloud"
NEBIUS_PIPELINE_NEBIUS_REGION="us-central1"

NEBIUS_PIPELINE_WHISPER_IMAGE="ghcr.io/darko-mesaros/nebius-whisper:latest"
NEBIUS_PIPELINE_GPU_PLATFORM="gpu-h200-sxm"
NEBIUS_PIPELINE_GPU_PRESET="1gpu-16vcpu-200gb"

NEBIUS_PIPELINE_FFMPEG_IMAGE="lscr.io/linuxserver/ffmpeg:latest"
NEBIUS_PIPELINE_FFMPEG_CONTAINER_COMMAND="sh"

# Example values for us-central1. Adjust to match your project/region.
NEBIUS_PIPELINE_CPU_PLATFORM="cpu-d3"
NEBIUS_PIPELINE_CPU_PRESET="4vcpu-16gb"

NEBIUS_PIPELINE_JOB_TIMEOUT_MINUTES="30"
NEBIUS_PIPELINE_JOB_DISK_GIB="250"
